{
  "_comment": "TEMPLATE — do not use directly. Run Install.ps1 to generate settings.json with absolute paths.",
  "_install": "pwsh $env:USERPROFILE\\.claude\\Install.ps1",

  "skills": {
    "directory": "{{CLAUDE_DIR}}\\skills"
  },
  "env": {
    "DISPATCHER_PROFILE_DIR": "{{CLAUDE_DIR}}"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -NonInteractive -File \"{{CLAUDE_DIR}}\\hooks\\on-prompt.ps1\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -NonInteractive -File \"{{CLAUDE_DIR}}\\hooks\\pre-bash.ps1\""
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(pwsh*)",
      "Bash(powershell*)",
      "Bash(gemini*)",
      "Bash(codex*)",
      "Bash(mods*)"
    ]
  }
}
