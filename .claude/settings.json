{
  "skills": {
    "directory": ".claude/skills"
  },
  "env": {
    "DISPATCHER_PROJECT_ROOT": "."
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -NonInteractive -File .claude/hooks/on-prompt.ps1"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -NonInteractive -File .claude/hooks/pre-bash.ps1"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(pwsh*)",
      "Bash(powershell*)",
      "Bash(gemini*)",
      "Bash(codex*)",
      "Bash(mods*)"
    ]
  }
}
