# Runtime artifacts (run history, logs, outputs) — not committed
.orchestrate/runs/
.orchestrate/index/
.orchestrate/config.toml

# Prompt temp files generated by agent scripts
*.prompt.txt
*.error.txt

# Session temp
$env:TEMP/chain-*/

# Generated by Install.ps1 — contains absolute paths specific to local machine
# Template is tracked as settings.json.template
settings.json
